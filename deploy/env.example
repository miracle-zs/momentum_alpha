BINANCE_API_KEY=replace_me
BINANCE_API_SECRET=replace_me
# 1 for Binance testnet, 0 for production
BINANCE_USE_TESTNET=1
# 1 enables real order submission in the polling worker
SUBMIT_ORDERS=0
STATE_FILE=/Users/your-user/momentum_alpha/var/state.json
# Optional space-separated USDⓈ-M perpetual symbol whitelist.
# Leave empty to auto-discover all Binance USDⓈ-M perpetual contracts.
SYMBOLS=
